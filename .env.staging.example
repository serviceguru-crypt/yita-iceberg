# Staging must point to a Firebase/GCP project separate from production.
APP_ENV=staging
NODE_ENV=production
APP_BASE_URL=https://staging.example.com

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=yita-iceberg-staging.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yita-iceberg-staging
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=yita-iceberg-staging.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
NEXT_PUBLIC_DEFAULT_FUNCTION_REGION=us-central1
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
NEXT_PUBLIC_ENABLE_APP_CHECK=true
NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=

FIREBASE_PROJECT_ID=yita-iceberg-staging
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_STORAGE_BUCKET=yita-iceberg-staging.appspot.com
SESSION_COOKIE_NAME=__session
SESSION_COOKIE_MAX_AGE_DAYS=5
DEFAULT_FUNCTION_REGION=us-central1
ENABLE_APP_CHECK_ENFORCEMENT=false
ENABLE_REPORT_SUMMARY_REBUILD=true
MAX_REPORT_EXPORT_DAYS=31
MAX_DETAIL_REPORT_DAYS=93

BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_NAME=
BOOTSTRAP_CONFIRM=false
BOOTSTRAP_EMERGENCY_OVERRIDE=false
BOOTSTRAP_ALLOW_PRODUCTION=false
BOOTSTRAP_PRODUCTION_CONFIRMATION=

SEED_ALLOW_PRODUCTION=false
SEED_PRODUCTION_CONFIRMATION=
PHASE6_MIGRATION_CONFIRM=false
PHASE6_MIGRATION_DRY_RUN=true
PHASE6_ALLOW_PRODUCTION=false
PHASE6_PRODUCTION_CONFIRMATION=
SMOKE_TEST_DRY_RUN=false
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
SMOKE_TEST_ALLOW_PRODUCTION=false
SMOKE_TEST_PRODUCTION_CONFIRMATION=
STAGING_SEED_CONFIRM=false
STAGING_SEED_DRY_RUN=true
STAGING_SEED_PASSWORD=
STAGING_SEED_RESET_PASSWORDS=false
STAGING_SEED_EMAIL_DOMAIN=example.test
