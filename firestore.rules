rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userPath());
    }

    function currentUser() {
      return get(userPath()).data;
    }

    function activeUser() {
      return hasUserProfile() && currentUser().isActive == true;
    }

    function platformRole() {
      return currentUser().platformRole;
    }

    function isAdmin() {
      return activeUser() && platformRole() in ['admin', 'super_admin'];
    }

    function isBranchManagerFor(branchId) {
      return activeUser()
        && platformRole() == 'branch_manager'
        && branchId in currentUser().assignedBranchIds;
    }

    function hasBranchAccess(branchId) {
      return isAdmin()
        || (activeUser() && branchId in currentUser().assignedBranchIds);
    }

    function orderBranch(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data.branchId;
    }

    match /users/{uid} {
      allow read: if activeUser() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    match /branches/{branchId} {
      allow read: if hasBranchAccess(branchId);
      allow write: if false;

      match /products/{productId} {
        allow read: if hasBranchAccess(branchId);
        allow write: if false;
      }

      match /inventory/{productId} {
        allow read: if hasBranchAccess(branchId);
        allow write: if false;
      }
    }

    match /products/{productId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /customers/{customerId} {
      allow read: if activeUser() && hasBranchAccess(resource.data.branchId);
      allow write: if false;
    }

    match /orders/{orderId} {
      allow read: if activeUser() && hasBranchAccess(resource.data.branchId);
      allow write: if false;

      match /payments/{paymentId} {
        allow read: if activeUser() && hasBranchAccess(orderBranch(orderId));
        allow write: if false;
      }
    }

    match /stockMovements/{movementId} {
      allow read: if activeUser() && hasBranchAccess(resource.data.branchId);
      allow write: if false;
    }

    match /financialTransactions/{transactionId} {
      allow read: if activeUser() && hasBranchAccess(resource.data.branchId);
      allow write: if false;
    }

    match /saleReversals/{reversalId} {
      allow read: if activeUser() && hasBranchAccess(resource.data.branchId);
      allow write: if false;
    }

    match /auditLogs/{auditId} {
      allow read: if isAdmin() || isBranchManagerFor(resource.data.branchId);
      allow write: if false;
    }

    match /settings/company {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /settings/branches/{branchId} {
      allow read: if hasBranchAccess(branchId);
      allow write: if false;
    }

    match /idempotencyRecords/{recordId} {
      allow read, write: if false;
    }

    match /paymentProofUploadIntents/{intentId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
