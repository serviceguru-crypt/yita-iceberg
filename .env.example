# Firebase web config exposed to the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
NEXT_PUBLIC_DEFAULT_FUNCTION_REGION=us-central1

# Local development toggles.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
NEXT_PUBLIC_ENABLE_APP_CHECK=false
NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# Server-only configuration. Never expose these with NEXT_PUBLIC_ prefixes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_FILE=
FIREBASE_STORAGE_BUCKET=
SESSION_COOKIE_NAME=__session
SESSION_COOKIE_MAX_AGE_DAYS=5
APP_BASE_URL=http://localhost:3000
APP_ENV=local
NODE_ENV=development

# Bootstrap-only values for the first super-admin. Never commit real values.
BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_NAME=
BOOTSTRAP_CONFIRM=false
BOOTSTRAP_EMERGENCY_OVERRIDE=false
BOOTSTRAP_ALLOW_PRODUCTION=false
BOOTSTRAP_PRODUCTION_CONFIRMATION=

# Script guard values. Keep production confirmations blank until the exact runbook step.
SEED_ALLOW_PRODUCTION=false
SEED_PRODUCTION_CONFIRMATION=
PHASE6_MIGRATION_CONFIRM=false
PHASE6_MIGRATION_DRY_RUN=true
PHASE6_ALLOW_PRODUCTION=false
PHASE6_PRODUCTION_CONFIRMATION=
SMOKE_TEST_DRY_RUN=true
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
SMOKE_TEST_ALLOW_PRODUCTION=false
SMOKE_TEST_PRODUCTION_CONFIRMATION=
# Operational config.
DEFAULT_FUNCTION_REGION=us-central1
ENABLE_APP_CHECK_ENFORCEMENT=false
ENABLE_REPORT_SUMMARY_REBUILD=false
MAX_REPORT_EXPORT_DAYS=31
MAX_DETAIL_REPORT_DAYS=93
