# Firebase web config exposed to the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Local development toggles.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
NEXT_PUBLIC_ENABLE_APP_CHECK=false
NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# Server-only configuration. Never expose these with NEXT_PUBLIC_ prefixes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=

# Bootstrap-only values for the first super-admin. Never commit real values.
BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_NAME=
BOOTSTRAP_CONFIRM=false
BOOTSTRAP_EMERGENCY_OVERRIDE=false
