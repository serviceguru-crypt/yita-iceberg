# Local development uses the Firebase Emulator Suite by default.
APP_ENV=local
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=yita-iceberg-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yita-iceberg-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=yita-iceberg-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:local
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
NEXT_PUBLIC_DEFAULT_FUNCTION_REGION=us-central1
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
NEXT_PUBLIC_ENABLE_APP_CHECK=false
NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=

FIREBASE_PROJECT_ID=yita-iceberg-dev
FIREBASE_STORAGE_BUCKET=yita-iceberg-dev.appspot.com
SESSION_COOKIE_NAME=__session
SESSION_COOKIE_MAX_AGE_DAYS=5
DEFAULT_FUNCTION_REGION=us-central1
ENABLE_APP_CHECK_ENFORCEMENT=false
ENABLE_REPORT_SUMMARY_REBUILD=false
MAX_REPORT_EXPORT_DAYS=31
MAX_DETAIL_REPORT_DAYS=93

BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.test
BOOTSTRAP_SUPER_ADMIN_NAME=Local Super Admin
BOOTSTRAP_CONFIRM=false
BOOTSTRAP_EMERGENCY_OVERRIDE=false
BOOTSTRAP_ALLOW_PRODUCTION=false
BOOTSTRAP_PRODUCTION_CONFIRMATION=

SEED_ALLOW_PRODUCTION=false
SEED_PRODUCTION_CONFIRMATION=
PHASE6_MIGRATION_CONFIRM=false
PHASE6_MIGRATION_DRY_RUN=true
PHASE6_ALLOW_PRODUCTION=false
PHASE6_PRODUCTION_CONFIRMATION=
